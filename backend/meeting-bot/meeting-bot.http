@meeting_bot_HostAddress = http://localhost:5213

GET {{meeting_bot_HostAddress}}/api/baseline/verify
Accept: application/json

###

POST {{meeting_bot_HostAddress}}/api/meetings/start
Content-Type: application/json

{
  "roomId": "room-001",
  "meetingJoinUrl": "https://teams.microsoft.com/l/meetup-join/..."
}

###

POST {{meeting_bot_HostAddress}}/api/meetings/leave
Content-Type: application/json

{
  "roomId": "room-001",
  "reason": "manual-test-stop"
}
