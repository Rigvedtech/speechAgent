# Copy to .env in this folder.

Graph__TenantId=
Graph__ClientId=
Graph__ClientSecret=

# ACS resource connection string (Azure portal → Keys)
Acs__ConnectionString=endpoint=https://your-resource.communication.azure.com/;accesskey=
# Optional: reuse same bot user across restarts (create via first run log if empty)
Acs__BotCommunicationUserId=

# Public HTTPS (ngrok / dev tunnel) — required for ACS callbacks and media WebSocket
MeetingBot__CallbackBaseUrl=https://your-tunnel.example.com
MeetingBot__OrganizerUserIdOrUpn=user@yourtenant.onmicrosoft.com
# Graph = join Teams meetings (recommended). Acs = Call Automation only (no Teams meeting link in REST API).
MeetingBot__MeetingJoinBackend=Graph

MeetingBot__AutoLeaveSeconds=0
MeetingBot__SttSuppressionAfterPlaySeconds=5
MeetingBot__SttWebSocketUrl=ws://127.0.0.1:8020/stt
MeetingBot__FixedGreetingLine=Hello, I am the interview bot.

AiBridge__Enabled=true
AiBridge__BaseUrl=http://127.0.0.1:8010
