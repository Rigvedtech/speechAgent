# Copy to .env in this folder. Values here override machine/user env when using DotNetEnv (see Program.cs).

MeetingBot__AutoLeaveSeconds=0
MeetingBot__EnableSttVoiceLoop=true
MeetingBot__SttLocalAudioSource=Loopback
MeetingBot__SttSuppressionAfterPlaySeconds=5
MeetingBot__SttWebSocketUrl=ws://127.0.0.1:8020/stt

# In-meeting STT (any Teams client): set UseApplicationHostedMedia=true and complete MediaPlatform (certificate + public IP/ports + FQDN). See README "App-hosted media".
MeetingBot__UseApplicationHostedMedia=false
MeetingBot__PlaceCallEndpointUrl=https://graph.microsoft.com/v1.0
MediaPlatform__CertificateThumbprint=
MediaPlatform__InstanceInternalPort=8445
MediaPlatform__InstancePublicPort=8445
MediaPlatform__InstancePublicIPAddress=
MediaPlatform__ServiceFqdn=
