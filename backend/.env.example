# =============================================================================
# SpeechAgent — backend/.env.example
# Copy to backend/.env and fill secrets. Restart api_server.py after changes.
# Production turn-taking: soft/hard silence, topic polls, stage gate
# =============================================================================

# --- PostgreSQL (Phase 0 auth / CRUD) ---
# Example for local pgAdmin DB named prabhat_DB:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/prabhat_DB
DATABASE_URL=
APP_ENV=development
# Generate e.g. python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
JWT_ISSUER=speechagent
JWT_AUDIENCE=speechagent-api

# CV/JD file storage (relative to backend/ unless absolute)
# --- Documents (uploaded CV/JD binaries) ---
DOCUMENT_UPLOAD_DIR=uploads
DOCUMENT_MAX_BYTES=15728640

# --- ATS ---
# Master key for encrypting per-org API keys in organization.ats_api_key_encrypted.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or use any long passphrase (SHA-256 derived). Falls back to JWT_SECRET in development only.
ATS_SECRET_ENCRYPTION_KEY=

# Optional legacy fallback: env var name referenced from ats_config.api_key_env
# ATS_API_KEY=

# --- Groq LLM ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EVALUATOR_MODEL=llama-3.1-8b-instant
GROQ_EVALUATOR_MAX_TOKENS=250
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=95
GROQ_REQUEST_TIMEOUT_SEC=45.0

# --- Ollama fallback ---
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EVALUATOR_FALLBACK=false

# --- n8n webhooks ---
N8N_CV_URI=http://localhost:5678/webhook/cv_textExtractor
N8N_JD_URI=http://localhost:5678/webhook/jd_textExtractor
N8N_QUESTIONS_URI=http://localhost:5678/webhook/questionGenrator
N8N_EXTRACTION_TIMEOUT_SEC=180

# --- Sarvam AI (primary STT/TTS) ---
SARVAM_API_KEY=
SARVAM_STT_ENABLED=true
SARVAM_TTS_ENABLED=true
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=en-IN
SARVAM_STT_MODE=transcribe
SARVAM_STT_HIGH_VAD=true
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SAMPLE_RATE=24000
# Slightly slower + cooler = clearer meeting audio
SARVAM_TTS_PACE=0.88
SARVAM_TTS_TEMPERATURE=0.28
TTS_STREAMING_ENABLED=true
SARVAM_MAX_RETRIES=3
SARVAM_RETRY_BASE_SECONDS=1.0
STT_FALLBACK_ENABLED=true
TTS_FALLBACK_ENABLED=true
HINGLISH_WHISPER_FALLBACK=true

# Soft endpoint ~2.5s; merge ~0.5s → hard end ~3.0s if candidate does not continue
SARVAM_LOCAL_SILENCE_SEC=2.5
SARVAM_STT_COLLECT_DEADLINE_SEC=5
SARVAM_STT_COLLECT_DEADLINE_MAX_SEC=60
SARVAM_STT_TRANSCRIBE_TIMEOUT_SEC=12
SARVAM_STT_TRANSCRIBE_TIMEOUT_MAX_SEC=90
SARVAM_STT_TRAILING_SILENCE_SEC=0.4
SARVAM_STT_WAIT_AFTER_END_SEC=0.25
SARVAM_QUALITY_MIN_UTTERANCE_SEC=2.5
SARVAM_QUALITY_MIN_CHARS=12

# --- Whisper fallback ---
MODEL_SIZE=tiny.en
WHISPER_LOCAL_SILENCE_SEC=1.5
WHISPER_PRELOAD_ENABLED=true

# --- Edge-TTS fallback ---
TTS_VOICE=en-IN-PrabhatNeural
TTS_RATE=+10%
TTS_REDUCE_PAUSES=true

# --- Audio pipeline ---
SAMPLE_RATE=16000
CHANNELS=1

BOT_NAME=Prabhat

# --- Recall.ai ---
RECALL_REGION=ap-northeast-1
RECALL_API_KEY=
RECALL_USE_OUTPUT_MEDIA=true
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=5213
# Public URLs — set to your machine / ngrok (same as local .env)
PUBLIC_WEBSOCKET_URL=ws://your-server-ip:5213
PUBLIC_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.dev
PUBLIC_NGROK_URL=https://your-ngrok-url.ngrok-free.dev
LOBBY_TIMEOUT_MINUTES=10

# --- Microsoft Teams bot (legacy) ---
Microsoft_App_Id=
Microsoft_App_Secret=
AssemblyAI_API_KEY=

# =============================================================================
# INTERVIEW ORCHESTRATION
# =============================================================================

MAX_QUESTIONS=15
MAX_INTERVIEW_MINUTES=30
MAX_STRIKES=3
MAX_OFF_TOPIC_REDIRECTS=2
ABUSE_MAX_WARNINGS=1

# Stage-1 gate: Q1–Q7 avg >= threshold after Q8 finishes → continue Q9–Q15
CONTINUE_AVG_THRESHOLD=6.5
STAGE1_QUESTION_COUNT=7
STAGE1_BRIDGE_QUESTION=8
ROLLING_WINDOW=7
STAGE1_GATE_WAIT_SEC=8.0

MAX_QUESTION_REPEATS=2
MAX_QUESTION_REPHRASES=1
NAME_NORMALIZE_ENABLED=true

# --- Soft / hard answer end ---
MIN_ANSWER_WORDS=8
MIN_SHORT_COMPLETE_WORDS=5
MAX_ANSWER_CONTINUATIONS=2
INCOMPLETE_ANSWER_CHECK_ENABLED=true

MAX_ANSWER_SEC=420
CORE_ANSWER_SOFT_SILENCE_SEC=2.0
CORE_LONG_ANSWER_SILENCE_SEC=2.0
CORE_LONG_ANSWER_SPEECH_SEC=8.0
# After soft end, keep listening this long; speech resumes → merge same answer
CORE_ANSWER_MERGE_WINDOW_SEC=0.5
CORE_ANSWER_MAX_HOLD_SEC=420
TURN_MERGE_ENABLED=true
TURN_MERGE_WINDOW_SEC=0.5
TURN_MERGE_MIN_AUDIO_SEC=1.5
TURN_MERGE_MIN_CHARS=12
TURN_MERGE_MIN_HOLD_SEC=1.0
TURN_MERGE_MAX_SHORT_HOLD_SEC=2.0
TURN_FLUSH_GUARD_MIN_CHARS=30
TURN_FLUSH_DEFER_SEC=6
# Speak next Q immediately; score in background
ANSWER_ACK_BEFORE_EVAL=false
PARALLEL_SCORE_ENABLED=true
CLARIFIER_REPLY_SILENCE_SEC=1.5

# --- Mid-answer: topic poll ONLY (old depth/slot interrupts off) ---
USER_BARGE_IN_ENABLED=false
BOT_INTERRUPT_ENABLED=true
BOT_INTERRUPT_MIN_PARTIAL_SEC=3
BOT_INTERRUPT_GATE_MIN_CONFIDENCE=0.75
BOT_INTERRUPT_CLARIFIER_ON_TRACK=false
BOT_INTERRUPT_MAX_DEPTH_CLARIFIERS_PER_Q=0
BOT_INTERRUPT_MAX_CLARIFIERS_PER_Q=0
BOT_INTERRUPT_DRAG_REPHRASE_MAX=0
BOT_INTERRUPT_MAX_DRAG_DEPTH_PER_Q=0
CLARIFIER_ON_TRACK_MIN_SPEECH_SEC=999
CLARIFIER_MIN_INTERVAL_SEC=999
CLARIFIER_REPLY_SCORE_MIN_CHARS=120
MAIN_QUESTION_INTERRUPT_COOLDOWN_SEC=5
MID_ANSWER_BOT_COOLDOWN_SEC=8
DRAG_SKIP_SCORE=2
DRAG_CONTEXT_MIN_OVERLAP=1
PROGRESS_GATE_LONG_ANSWER_SEC=45
PROGRESS_GATE_MIN_TOPIC_OVERLAP=1
PROGRESS_GATE_RULE_DRAG_MIN_SEC=45
PROGRESS_GATE_RULE_DRAG_MIN_WORDS=40
PROGRESS_GATE_UNCLEAR_ESCALATION_CHECKS=2

# Topic check every 30s of speech (clock from speech start)
ANSWER_TOPIC_POLL_INTERVAL_SEC=30
ANSWER_TOPIC_POLL_WINDOW_SEC=30
MAX_TOPIC_REDIRECTS_PER_QUESTION=2
# Legacy interrupt slots disabled
ANSWER_FIRST_CHECK_SEC=9999
ANSWER_INTERRUPT_2_AFTER_SEC=9999
ANSWER_SECOND_CHECK_SEC=9999
ANSWER_MAX_INTERRUPTS=0
ANSWER_INTERRUPT_SLOT_TOLERANCE_SEC=3
ANSWER_DEPTH_CHECK_WINDOW_SEC=30
ANSWER_DRAG_GRACE_SEC=0

# --- Presence: only before answer starts ---
POST_TTS_SILENCE_CHECK_ENABLED=true
POST_TTS_SILENCE_MIN_AFTER_QUESTION_SEC=22
POST_QUESTION_SILENCE_STEP1_SEC=22
POST_QUESTION_SILENCE_STEP2_SEC=12
POST_QUESTION_FINAL_WRAP_SEC=15
MAX_PRESENCE_CHECKS_PER_QUESTION=1
PRESENCE_ONLY_AFTER_QUESTION=true
PRESENCE_SKIP_DURING_ANSWER=true

# --- Intro ---
INTRO_MIN_CHARS=80
INTRO_MIN_SPEECH_SEC=20
INTRO_MERGE_WINDOW_SEC=10
STALE_ANSWER_GUARD_SEC=12
STALE_ANSWER_MAX_CHARS=220

# --- Turn intent ---
TURN_INTENT_CLASSIFIER_ENABLED=true
TURN_INTENT_MAX_CHARS=150
TURN_INTENT_MIN_CONFIDENCE=0.65

# =============================================================================
# TURN-TAKING BUDGET
# =============================================================================
ANSWER_INITIAL_LISTEN_SEC=60
ANSWER_EXTEND_STEP_SEC=30
ANSWER_MAX_TOTAL_SEC=420

# Full server logs under backend/logs/ (transcripts stay in transcripts/)
FILE_LOGGING_ENABLED=true

# Live Sarvam STT while speaking (cuts end-of-answer rebatch latency)
STREAM_STT_ENABLED=true
STREAM_STT_FINALIZE_SEC=0.8
STREAM_STT_MIN_CHARS=8
SHORT_UTTERANCE_MAX_SEC=5.0
SHORT_UTTERANCE_SILENCE_SEC=1.5
INCOMPLETE_MERGE_WINDOW_SEC=3.5
