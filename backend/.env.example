# Environment Variables for Recall.ai Integration

# ===== RECALL.AI API =====
RECALL_API_KEY=your_recall_api_key_here

# ===== WEBSOCKET SERVER =====
# Local WebSocket server configuration
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765

# Public WebSocket URL (use ngrok for development)
# Example: wss://abc123.ngrok-free.app
PUBLIC_WEBSOCKET_URL=

# ===== STT ENGINE =====
MODEL_SIZE=small.en
SAMPLE_RATE=16000
CHANNELS=1
SILENCE_DURATION=0.8

# ===== LLM =====
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_MODEL=llama3.2:3b

# ===== TTS =====
TTS_VOICE=en-IN-PrabhatNeural
TTS_RATE=+0%

# ===== STARTUP =====
STARTUP_GREETING=Hello, I'm Prabhat, and I'll be your interviewer today. Let's begin when you're ready. Please introduce yourself briefly.
