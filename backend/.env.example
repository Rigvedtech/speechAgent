# ===== SARVAM AI CONFIGURATION (OPTIONAL) =====
# Get API key from: https://console.sarvam.ai/
SARVAM_API_KEY=

# Enable/Disable Sarvam AI providers (set to false to use only fallback engines)
SARVAM_STT_ENABLED=true
SARVAM_TTS_ENABLED=true

# STT Configuration (Saaras V3)
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=en-IN
SARVAM_STT_MODE=transcribe
# Modes: transcribe (default), translate, verbatim, translit, codemix
SARVAM_STT_HIGH_VAD=true

# TTS Configuration (Bulbul V3)
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
# Speakers: shubh, anushka, meera, and 30+ others
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SAMPLE_RATE=16000
# Sample rates: 8000, 16000, 22050, 24000
SARVAM_TTS_PACE=1.2
# Pace: 0.5 (slower) to 2.0 (faster), 1.0 = normal
SARVAM_TTS_TEMPERATURE=0.6
# Temperature: 0.01 (deterministic) to 1.0 (varied), higher = more variation

# Fallback Configuration
STT_FALLBACK_ENABLED=true
TTS_FALLBACK_ENABLED=true

# Retry Configuration
SARVAM_MAX_RETRIES=3
SARVAM_RETRY_BASE_SECONDS=1.0

# Interview language (POST /api/start language_mode; default when omitted)
DEFAULT_INTERVIEW_LANGUAGE=english
LANG_ENGLISH_STT_LANGUAGE=en-IN
LANG_ENGLISH_STT_MODE=transcribe
LANG_ENGLISH_TTS_LANGUAGE=en-IN
LANG_HINGLISH_STT_LANGUAGE=hi-IN
LANG_HINGLISH_STT_MODE=codemix
LANG_HINGLISH_TTS_LANGUAGE=hi-IN

# Recall.ai bot output mode
# false = output_audio file upload (reliable fallback; 4-8s latency)
# true  = Output Media webpage (ultra-low latency; requires PUBLIC_NGROK_URL below)
RECALL_USE_OUTPUT_MEDIA=false

# Public HTTPS base URL of this server — used to build the Output Media webpage URL.
# Must be HTTPS (Recall.ai will NOT load plain http pages).
# Get this from `ngrok http 8000` → copy the https://... URL.
# Example: https://abc123.ngrok-free.app
PUBLIC_NGROK_URL=

# Comma-separated origins allowed for the recruiter frontend (CORS)
# Example: http://localhost:5173,https://recruiter.yourcompany.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# n8n webhook for JD/CV document extraction (backend proxies frontend uploads)
N8N_URI=http://localhost:5678/webhook/jd-cv_detail_extraction

# ===== EXISTING CONFIGURATION =====

# Groq API key for cloud LLM backend
# Leave empty or use your_api_key_here to use local Ollama
GROQ_API_KEY=

# --- Audio / VAD (STT pipeline) ---
SAMPLE_RATE=16000
CHANNELS=1
SILENCE_DURATION=1.0

# --- Speech-to-text (faster-whisper model id - fallback only if Sarvam disabled) ---
MODEL_SIZE=tiny.en
# Options: tiny.en, base.en, small.en, medium.en, large-v2

# --- LLM ---
OLLAMA_MODEL=llama3.2:3b
GROQ_MODEL=llama-3.3-70b-versatile

# --- Text-to-speech (Microsoft Edge voice name - fallback only if Sarvam disabled) ---
TTS_VOICE=en-IN-PrabhatNeural
TTS_RATE=+35%
TTS_REDUCE_PAUSES=true

BOT_NAME=Prabhat

# ===== RECALL.AI INTEGRATION =====
RECALL_API_KEY=

# WebSocket server
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=5213

# Public WebSocket URL (required - get from ngrok or use your public IP)
PUBLIC_WEBSOCKET_URL=ws://your-server-ip:5213
PUBLIC_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.dev

# --- Mid-answer progress gate & presence ---
POST_TTS_SILENCE_CHECK_SEC=18.0
POST_TTS_SILENCE_MIN_AFTER_QUESTION_SEC=18.0
TURN_FLUSH_GUARD_MIN_CHARS=30
TURN_FLUSH_DEFER_SEC=8.0
DRAG_REPHRASE_SCORE_GRACE_SEC=15.0
DRAG_SKIP_SCORE=2
BOT_INTERRUPT_MAX_DRAG_DEPTH_PER_Q=1
DRAG_CONTEXT_MIN_OVERLAP=1
# Mid-answer orchestration — prevent overlapping bot speech
MAIN_QUESTION_INTERRUPT_COOLDOWN_SEC=25.0
MID_ANSWER_BOT_COOLDOWN_SEC=18.0
STALE_ANSWER_GUARD_SEC=12.0
STALE_ANSWER_MAX_CHARS=220
CLARIFIER_REPLY_SCORE_MIN_CHARS=40
INTRO_MIN_CHARS=80
INTRO_MIN_SPEECH_SEC=20.0
INTRO_MERGE_WINDOW_SEC=10.0
CLARIFIER_MIN_SPEECH_SEC=25.0
CLARIFIER_ON_TRACK_MIN_SPEECH_SEC=18.0
CLARIFIER_MIN_INTERVAL_SEC=20.0
BOT_INTERRUPT_MIN_SPEECH_SEC=15.0
BOT_INTERRUPT_CHECK_INTERVAL_SEC=10.0
# ON_TRACK depth clarifiers (unexplained jargon) — max 2 per question
BOT_INTERRUPT_MAX_DEPTH_CLARIFIERS_PER_Q=2
BOT_INTERRUPT_MIN_DEPTH_CLARIFIERS_PER_Q=0
# DRAG (off-topic) rephrases — min 1, max 2 per question before force-complete
BOT_INTERRUPT_DRAG_REPHRASE_MIN=1
BOT_INTERRUPT_DRAG_REPHRASE_MAX=2
BOT_INTERRUPT_DRAG_STRIKES_MAX=3
# true = ON_TRACK depth probes; false = only DRAG interrupts mid-answer
BOT_INTERRUPT_CLARIFIER_ON_TRACK=true
CORE_ANSWER_MERGE_WINDOW_SEC=15.0
CORE_LONG_ANSWER_SPEECH_SEC=18.0
CORE_LONG_ANSWER_SILENCE_SEC=2.2
CORE_ANSWER_MAX_HOLD_SEC=45.0
HINGLISH_WHISPER_FALLBACK=true
GROQ_REQUEST_TIMEOUT_SEC=45.0
OLLAMA_EVALUATOR_FALLBACK=false
# Base timeout; scales up for long answers (see config.sarvam_transcribe_timeout_sec)
SARVAM_STT_TRANSCRIBE_TIMEOUT_SEC=12.0
SARVAM_STT_TRANSCRIBE_TIMEOUT_MAX_SEC=90.0
SARVAM_STT_COLLECT_DEADLINE_MAX_SEC=60.0
LOBBY_TIMEOUT_MINUTES=15
