# Google AI Studio / Gemini API key (same type as text + image).
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional alias if you already standardize on this name:
# GEMINI_API_KEY=

# Live native-audio model (speech in -> speech out). IDs change over time — confirm in README links.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Text-only smoke test model (Live API, not necessarily native audio):
GEMINI_LIVE_SMOKE_MODEL=gemini-live-2.5-flash-preview

# Voice + locale (passed in LiveConnectConfig.speech_config when supported)
GEMINI_LANGUAGE_CODE=en-US
GEMINI_VOICE_NAME=Puck

# Optional sounddevice indices (integer). Leave unset for OS default devices.
# INPUT_AUDIO_DEVICE=
# OUTPUT_AUDIO_DEVICE=
