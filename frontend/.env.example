# Development — full app via Vite proxy (leave VITE_LANDING_ONLY unset)
# Get Started → /login
VITE_API_BASE_URL=

# Production landing-only (Vercel) — see .env.production
# Get Started → https://rigvedtech.com (or VITE_GET_STARTED_URL)
# VITE_LANDING_ONLY=true
# VITE_GET_STARTED_URL=https://rigvedtech.com
# VITE_API_BASE_URL=

# Full app production deploy (Azure VM)
# Get Started → /login
# VITE_LANDING_ONLY=false
# VITE_API_BASE_URL=
