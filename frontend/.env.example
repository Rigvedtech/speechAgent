# Development — full app via Vite proxy (leave VITE_LANDING_ONLY unset)
VITE_API_BASE_URL=

# Production landing-only (Vercel) — see .env.production
# VITE_LANDING_ONLY=true
# VITE_API_BASE_URL=

# Full app production deploy
# VITE_LANDING_ONLY=false
# VITE_API_BASE_URL=https://your-backend.example.com
